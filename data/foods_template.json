{
  "_README": "後で埋めるための雛形。各項目を data/foods.json の items[] にコピーし、空欄を埋めて使う。id/name/name_kana/name_en/category/category_label までは事前に設定済み。summary_ok/summary_ng は OK/NG キーワードを5〜15文字程度で(例: 'ハリ・重み・葉が鮮やか')。図解SVG は svg/parts/<id>_ok.svg と svg/parts/<id>_ng.svg の2ファイルを用意する。ファイル命名はidに従うのでJSONには書かない。詳細画面の図解は JS の buildDiagram(food) が自動生成する。",
  "_categories": {
    "vegetable": "野菜",
    "fruit": "果物",
    "mushroom": "きのこ",
    "fish": "魚介",
    "meat": "肉類",
    "egg_dairy_bean": "卵・乳・豆",
    "game_meat": "ジビエ"
  },
  "_field_template": {
    "id": "string (URL用 英数字)",
    "name": "表示名(日本語)",
    "name_kana": "ひらがな(検索用)",
    "name_en": "英語名(検索用)",
    "category": "_categoriesのキー",
    "category_label": "_categoriesの値",
    "subcategory": "細分類",
    "color_theme": "#XXXXXX 食材を表す色",
    "accent_color": "#XXXXXX アクセント色 (一覧カードの細ストライプに使用)",
    "season": [
      "X月"
    ],
    "season_peak": "春/夏/秋/冬 等",
    "ok_points": [
      "4項目程度 (詳細セクションに全文表示)"
    ],
    "ng_points": [
      "4項目程度 (詳細セクションに全文表示)"
    ],
    "summary_ok": "短キーワード5〜15文字 (図解キャプションに表示)",
    "summary_ng": "短キーワード5〜15文字 (図解キャプションに表示)",
    "storage": {
      "method": "",
      "duration": "",
      "tips": ""
    },
    "usage_tips": "部位別の使い分けや調理のコツ",
    "nutrition_highlight": "栄養面のハイライト",
    "_files_to_create": [
      "svg/parts/<id>_ok.svg  (OK食材イラストのみ。タイトル・キャプション無し)",
      "svg/parts/<id>_ng.svg  (NG食材イラストのみ。タイトル・キャプション無し)"
    ]
  },
